APP_ENV=local
APP_NAME=local-salesforce-ai-engineer
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///state/agent.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Salesforce CLI / org connection (optional — simulated when sf CLI unavailable)
SF_DEFAULT_ORG_ALIAS=
SF_AUTH_TYPE=sfdx
SF_ORG_ID=
SF_INSTANCE_URL=https://login.salesforce.com
SF_API_VERSION=60.0
SF_IS_PRODUCTION=false
SF_CLI_ENABLED=true

